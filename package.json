{
  "name": "grid-sensor-pipeline",
  "version": "0.1.0",
  "private": true,
  "description": "Serverless IoT grid sensor event processing pipeline",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\" \"infra/**/*.ts\" \"scripts/**/*.ts\"",
    "cdk": "cdk",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy --all",
    "destroy": "cdk destroy --all; bash scripts/post-destroy-check.sh",
    "destroy:check": "bash scripts/post-destroy-check.sh",
    "simulate": "ts-node scripts/simulate.ts"
  },
  "dependencies": {
    "@aws-lambda-powertools/idempotency": "^2",
    "@aws-lambda-powertools/logger": "^2",
    "@aws-lambda-powertools/metrics": "^2",
    "@aws-lambda-powertools/tracer": "^2",
    "@aws-sdk/client-dynamodb": "^3",
    "@aws-sdk/client-iot-data-plane": "^3",
    "@aws-sdk/client-kinesis": "^3",
    "@aws-sdk/client-lambda": "^3",
    "@aws-sdk/client-sns": "^3",
    "@aws-sdk/lib-dynamodb": "^3",
    "@langchain/aws": "^1.3.7",
    "@langchain/core": "^1.1.45",
    "@langchain/langgraph": "^1.3.0",
    "zod": "^3"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.14.0",
    "@types/aws-lambda": "^8",
    "@types/jest": "^29",
    "@types/node": "^20",
    "aws-cdk": "^2.1121.0",
    "aws-cdk-lib": "^2.253.0",
    "constructs": "^10",
    "esbuild": "^0.20",
    "eslint": "^9",
    "jest": "^29",
    "source-map-support": "^0.5",
    "ts-jest": "^29",
    "ts-node": "^10",
    "typescript": "^5",
    "typescript-eslint": "^8"
  }
}
